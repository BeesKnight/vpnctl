#!/bin/bash
# vpnctl postinst: dpkg/apt is already holding the package-manager lock while
# this script runs, so this file must never call apt-get. Regular Debian/Kali
# packages belong in nfpm.yaml's Depends. The upstream components that are
# usually not available from the base repos (sing-box, Xray-core, tun2socks,
# and AmneziaWG userspace) are installed from GitHub release assets when
# possible, with an AmneziaWG source build as the fallback (Xray-core and
# tun2socks ship prebuilt for every arch vpnctl supports, so they have none).
set -u

STATE_DIR="/var/lib/vpnctl"
DEPS_FILE="$STATE_DIR/installed_by_vpnctl.json"
BIN_DIR="/usr/bin"
mkdir -p "$STATE_DIR"

log() { echo "vpnctl postinst: $*"; }

ARCH="$(dpkg --print-architecture 2>/dev/null || uname -m)"
case "$ARCH" in
  amd64|x86_64) NORM_ARCH="amd64" ;;
  arm64|aarch64) NORM_ARCH="arm64" ;;
  *) NORM_ARCH="" ;;
esac

installed_singbox=false
installed_xray=false
installed_tun2socks=false
installed_awg_tools=false
installed_amneziawg_go=false

# RELEASE_CACHE_DIR holds one cached /releases/latest JSON response per
# repo (release_json below) so a repo whose release is consulted more than
# once in a single postinst run (amneziawg-tools, for both `awg` and
# `awg-quick`) doesn't hit the GitHub API twice, and so verify_checksum can
# search the same asset list install_binary_from_release already fetched
# for a companion checksums file, without a second API call.
RELEASE_CACHE_DIR="$(mktemp -d)"
trap 'rm -rf "$RELEASE_CACHE_DIR"' EXIT

release_json() {
  repo="$1"
  cache_file="$RELEASE_CACHE_DIR/$(printf '%s' "$repo" | tr '/' '_').json"
  if [ ! -s "$cache_file" ]; then
    curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" -o "$cache_file" 2>/dev/null || true
  fi
  [ -s "$cache_file" ] || return 1
  printf '%s' "$cache_file"
}

latest_release_urls() {
  repo="$1"
  cf="$(release_json "$repo")" || return 1
  jq -r '.assets[]?.browser_download_url' "$cf" 2>/dev/null
}

asset_matches() {
  url_lc="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  bin_lc="$(printf '%s' "$2" | tr '[:upper:]' '[:lower:]')"
  case "$url_lc" in
    *"$bin_lc"*linux*"$NORM_ARCH"*|*linux*"$NORM_ARCH"*"$bin_lc"*|*"$bin_lc"*"$NORM_ARCH"*linux*|*"$NORM_ARCH"*linux*"$bin_lc"*) return 0 ;;
    *) return 1 ;;
  esac
}

# verify_checksum best-effort-verifies a downloaded release asset against a
# companion checksums file in the same GitHub release (checksums.txt/
# SHA256SUMS/*.sha256/*.dgst — covers sing-box, Xray-core, and the common
# GoReleaser convention alike). Every binary installed this way ends up
# root-owned in /usr/bin and is later invoked as root (via nsenter, inside
# the kill-switch namespace) — previously nothing here checked that what
# got downloaded was actually what upstream published, so a compromised
# release asset or an on-path MITM would install silently.
#
# Returns 0 (proceed) when verified OK, *and* when verification genuinely
# isn't possible (no checksums file published for this release) — refusing
# every install just because a smaller upstream project doesn't publish
# checksums would be a worse regression than today's zero-verification
# baseline. Returns 1 (refuse) only when a checksums file was found and the
# hash actually didn't match — that's the real "something is wrong" signal.
verify_checksum() {
  repo="$1"
  asset_filename="$2"
  asset_path="$3"

  cf="$(release_json "$repo")" || {
    log "WARNING: could not verify checksum for $asset_filename (release metadata unavailable) — installing unverified"
    return 0
  }

  # Prefer a checksums file scoped to exactly this asset (Xray-core's
  # convention: one "<asset>.dgst" per platform binary in the same
  # release) before falling back to a single release-wide checksums file
  # (sing-box/GoReleaser convention) — a release with many per-platform
  # assets has many same-shaped checksum filenames, and grabbing the first
  # "*.dgst"-looking one regardless of which platform it belongs to would
  # compare our downloaded asset against an unrelated platform's hash,
  # turning a best-effort verification into a guaranteed false mismatch.
  checksums_url=""
  while IFS= read -r candidate; do
    case "$(basename "$candidate")" in
      "$asset_filename.dgst"|"$asset_filename.sha256"|"$asset_filename.sha256sum")
        checksums_url="$candidate"
        break
        ;;
    esac
  done <<EOF
$(jq -r '.assets[]?.browser_download_url' "$cf" 2>/dev/null)
EOF

  if [ -z "$checksums_url" ]; then
    while IFS= read -r candidate; do
      case "$(basename "$candidate" | tr '[:upper:]' '[:lower:]')" in
        *checksums*|*sha256sum*|sha256sums*)
          checksums_url="$candidate"
          break
          ;;
      esac
    done <<EOF
$(jq -r '.assets[]?.browser_download_url' "$cf" 2>/dev/null)
EOF
  fi

  if [ -z "$checksums_url" ]; then
    log "WARNING: $repo does not publish a checksums file for this release — installing $asset_filename unverified"
    return 0
  fi

  tmp_sums="$(mktemp)"
  if ! curl -fsSL "$checksums_url" -o "$tmp_sums" 2>/dev/null; then
    log "WARNING: could not download checksums file for $asset_filename — installing unverified"
    rm -f "$tmp_sums"
    return 0
  fi

  actual="$(sha256sum "$asset_path" 2>/dev/null | awk '{print $1}')"
  # Most projects' checksums files list "<hash>  <filename>" per line; some
  # (Xray-core's .dgst) are scoped to a single asset already and just have
  # one or more "ALGO= <hash>" lines with no filename to match against —
  # fall back to the first sha256-shaped hex string in the file.
  expected="$(grep -iF "$asset_filename" "$tmp_sums" 2>/dev/null | grep -oE '[0-9a-fA-F]{64}' | head -1)"
  if [ -z "$expected" ]; then
    expected="$(grep -oE '[0-9a-fA-F]{64}' "$tmp_sums" 2>/dev/null | head -1)"
  fi
  rm -f "$tmp_sums"

  if [ -z "$expected" ]; then
    log "WARNING: checksums file for $asset_filename didn't contain a recognizable sha256 — installing unverified"
    return 0
  fi

  actual_lc="$(printf '%s' "$actual" | tr '[:upper:]' '[:lower:]')"
  expected_lc="$(printf '%s' "$expected" | tr '[:upper:]' '[:lower:]')"
  if [ "$actual_lc" != "$expected_lc" ]; then
    log "ERROR: checksum mismatch for $asset_filename (expected $expected_lc, got $actual_lc) — refusing to install a possibly corrupted or tampered download"
    return 1
  fi
  log "checksum verified for $asset_filename"
  return 0
}

install_binary_from_release() {
  repo="$1"
  binary="$2"
  dest="$3"

  [ -n "$NORM_ARCH" ] || return 1
  url=""
  while IFS= read -r candidate; do
    if asset_matches "$candidate" "$binary"; then
      url="$candidate"
      break
    fi
  done <<EOF
$(latest_release_urls "$repo")
EOF
  [ -n "$url" ] || return 1

  tmp="$(mktemp -d)"
  asset="$tmp/asset"
  if ! curl -fsSL "$url" -o "$asset" 2>/dev/null; then
    rm -rf "$tmp"
    return 1
  fi
  if ! verify_checksum "$repo" "$(basename "$url")" "$asset"; then
    rm -rf "$tmp"
    return 1
  fi

  found=""
  case "$url" in
    *.tar.gz|*.tgz)
      mkdir -p "$tmp/extract"
      tar -xzf "$asset" -C "$tmp/extract" 2>/dev/null || true
      found="$(find "$tmp/extract" -type f -name "$binary" | head -1)"
      ;;
    *.tar.xz)
      mkdir -p "$tmp/extract"
      tar -xJf "$asset" -C "$tmp/extract" 2>/dev/null || true
      found="$(find "$tmp/extract" -type f -name "$binary" | head -1)"
      ;;
    *.zip)
      if command -v unzip >/dev/null 2>&1; then
        mkdir -p "$tmp/extract"
        unzip -qq "$asset" -d "$tmp/extract" 2>/dev/null || true
        found="$(find "$tmp/extract" -type f -name "$binary" | head -1)"
      fi
      ;;
    *)
      found="$asset"
      ;;
  esac

  if [ -n "$found" ] && install -m 0755 "$found" "$dest"; then
    rm -rf "$tmp"
    return 0
  fi
  rm -rf "$tmp"
  return 1
}

install_singbox() {
  if command -v sing-box >/dev/null 2>&1; then
    log "sing-box already present ($(command -v sing-box)), leaving it alone"
    return 0
  fi
  if install_binary_from_release "SagerNet/sing-box" "sing-box" "$BIN_DIR/sing-box"; then
    installed_singbox=true
    log "sing-box installed to $BIN_DIR/sing-box"
  else
    log "WARNING: could not install sing-box from GitHub release assets"
  fi
}

# install_named_asset_from_release downloads a release asset matched by its
# exact filename (rather than install_binary_from_release's substring
# guessing), for repos whose asset names don't spell out "amd64"/"arm64" the
# same way sing-box/amneziawg-tools do (Xray-core uses "64"/"arm64-v8a"), or
# that ship more than one asset per arch that a substring match could
# ambiguously prefer (tun2socks also publishes a "-v3" amd64 build, which is
# not safe to assume the target CPU supports). binary_glob matches the
# extracted file since it isn't always named the same as $2/dest either
# (tun2socks's archives contain e.g. "tun2socks-linux-amd64", not "tun2socks").
install_named_asset_from_release() {
  repo="$1"
  asset_name="$2"
  binary_glob="$3"
  dest="$4"

  url=""
  while IFS= read -r candidate; do
    case "$candidate" in
      */"$asset_name") url="$candidate"; break ;;
    esac
  done <<EOF
$(latest_release_urls "$repo")
EOF
  [ -n "$url" ] || return 1

  tmp="$(mktemp -d)"
  asset="$tmp/asset.zip"
  if ! curl -fsSL "$url" -o "$asset" 2>/dev/null; then
    rm -rf "$tmp"
    return 1
  fi
  if ! verify_checksum "$repo" "$asset_name" "$asset"; then
    rm -rf "$tmp"
    return 1
  fi
  mkdir -p "$tmp/extract"
  if ! unzip -qq "$asset" -d "$tmp/extract" 2>/dev/null; then
    rm -rf "$tmp"
    return 1
  fi
  found="$(find "$tmp/extract" -type f -name "$binary_glob" | head -1)"
  if [ -n "$found" ] && install -m 0755 "$found" "$dest"; then
    rm -rf "$tmp"
    return 0
  fi
  rm -rf "$tmp"
  return 1
}

install_xray() {
  if command -v xray >/dev/null 2>&1; then
    log "xray already present ($(command -v xray)), leaving it alone"
    return 0
  fi
  case "$NORM_ARCH" in
    amd64) xray_asset="Xray-linux-64.zip" ;;
    arm64) xray_asset="Xray-linux-arm64-v8a.zip" ;;
    *) xray_asset="" ;;
  esac
  if [ -n "$xray_asset" ] && install_named_asset_from_release "XTLS/Xray-core" "$xray_asset" "xray" "$BIN_DIR/xray"; then
    installed_xray=true
    log "xray installed to $BIN_DIR/xray"
  else
    log "WARNING: could not install xray from GitHub release assets — VLESS profiles need it"
  fi
}

install_tun2socks() {
  if command -v tun2socks >/dev/null 2>&1; then
    log "tun2socks already present ($(command -v tun2socks)), leaving it alone"
    return 0
  fi
  case "$NORM_ARCH" in
    amd64) t2s_asset="tun2socks-linux-amd64.zip" ;;
    arm64) t2s_asset="tun2socks-linux-arm64.zip" ;;
    *) t2s_asset="" ;;
  esac
  if [ -n "$t2s_asset" ] && install_named_asset_from_release "xjasonlyu/tun2socks" "$t2s_asset" "tun2socks*" "$BIN_DIR/tun2socks"; then
    installed_tun2socks=true
    log "tun2socks installed to $BIN_DIR/tun2socks"
  else
    log "WARNING: could not install tun2socks from GitHub release assets — VLESS profiles' TUN mode needs it"
  fi
}

build_amneziawg_go() {
  tmp="$(mktemp -d)"
  if git clone --depth 1 https://github.com/amnezia-vpn/amneziawg-go "$tmp/amneziawg-go" >/dev/null 2>&1 \
    && ( cd "$tmp/amneziawg-go" && make >/dev/null 2>&1 && install -m 0755 amneziawg-go "$BIN_DIR/amneziawg-go" ); then
    rm -rf "$tmp"
    return 0
  fi
  rm -rf "$tmp"
  return 1
}

build_amneziawg_tools() {
  tmp="$(mktemp -d)"
  if git clone --depth 1 https://github.com/amnezia-vpn/amneziawg-tools "$tmp/amneziawg-tools" >/dev/null 2>&1 \
    && ( cd "$tmp/amneziawg-tools/src" && make >/dev/null 2>&1 && make install >/dev/null 2>&1 ); then
    rm -rf "$tmp"
    return 0
  fi
  rm -rf "$tmp"
  return 1
}

install_amneziawg_go() {
  if command -v amneziawg-go >/dev/null 2>&1; then
    log "amneziawg-go already present ($(command -v amneziawg-go)), leaving it alone"
    return 0
  fi
  if install_binary_from_release "amnezia-vpn/amneziawg-go" "amneziawg-go" "$BIN_DIR/amneziawg-go"; then
    installed_amneziawg_go=true
    log "amneziawg-go installed to $BIN_DIR/amneziawg-go"
    return 0
  fi
  log "amneziawg-go release binary not available, falling back to source build"
  if build_amneziawg_go; then
    installed_amneziawg_go=true
    log "amneziawg-go built from source"
  else
    log "WARNING: amneziawg-go build failed"
  fi
}

install_amneziawg_tools() {
  if command -v awg >/dev/null 2>&1 && command -v awg-quick >/dev/null 2>&1; then
    log "awg/awg-quick already present, leaving them alone"
    return 0
  fi
  release_ok=true
  command -v awg >/dev/null 2>&1 || install_binary_from_release "amnezia-vpn/amneziawg-tools" "awg" "$BIN_DIR/awg" || release_ok=false
  command -v awg-quick >/dev/null 2>&1 || install_binary_from_release "amnezia-vpn/amneziawg-tools" "awg-quick" "$BIN_DIR/awg-quick" || release_ok=false
  if [ "$release_ok" = true ] && command -v awg >/dev/null 2>&1 && command -v awg-quick >/dev/null 2>&1; then
    installed_awg_tools=true
    log "amneziawg-tools installed from GitHub release assets"
    return 0
  fi

  log "amneziawg-tools release binaries not available, falling back to source build"
  if build_amneziawg_tools && command -v awg >/dev/null 2>&1 && command -v awg-quick >/dev/null 2>&1; then
    installed_awg_tools=true
    log "amneziawg-tools built from source"
  else
    log "WARNING: amneziawg-tools build failed"
  fi
}

install_singbox
install_xray
install_tun2socks
install_amneziawg_go
install_amneziawg_tools

cat > "$DEPS_FILE" <<EOF
{
  "sing_box": $installed_singbox,
  "xray_core": $installed_xray,
  "tun2socks": $installed_tun2socks,
  "amneziawg_tools": $installed_awg_tools,
  "amneziawg_go": $installed_amneziawg_go
}
EOF
log "dependency install record: $DEPS_FILE"

# --- vpnctld daemon: group, one-time migration, enable+start -------------
# vpnctl moved from "every CLI/TUI invocation manages netns/iptables/engine
# state itself, coordinating through ~/.local/state/vpnctl/active.json" to
# a privileged system service (vpnctld) that owns all of that in memory;
# vpnctl is now an unprivileged client talking to it over /run/vpnctl.sock.
# See DAEMON_MIGRATION.md.
VPNCTL_GROUP="vpnctl"

setup_daemon_group() {
  groupadd -f "$VPNCTL_GROUP"
  real_user="${SUDO_USER:-}"
  if [ -n "$real_user" ] && [ "$real_user" != "root" ]; then
    usermod -aG "$VPNCTL_GROUP" "$real_user"
    log "added $real_user to the '$VPNCTL_GROUP' group (log out/in, or run 'newgrp $VPNCTL_GROUP', for it to take effect in already-open shells)"
  else
    log "no non-root invoking user detected (\$SUDO_USER unset) — add the intended vpnctl user(s) to the '$VPNCTL_GROUP' group manually: usermod -aG $VPNCTL_GROUP <user>"
  fi
}

# migrate_from_file_based_model runs the same PID-kill/namespace/socket
# cleanup as packaging/prerm's force_teardown, applied here as a one-time
# upgrade migration. If this machine is upgrading from a pre-daemon vpnctl
# (every invocation tracking its own active.json), any leftover namespace
# or engine process from that old model has to be torn down *before*
# vpnctld starts for the first time — the daemon has no knowledge of it,
# so left alone it would either leave vpnctl0 orphaned forever or conflict
# with the daemon's own first `use`.
migrate_from_file_based_model() {
  home="$1"
  state_dir="$home/.local/state/vpnctl"
  active_json="$state_dir/active.json"
  [ -f "$active_json" ] || return 0

  log "found leftover active.json from the pre-daemon vpnctl at $active_json, tearing down before starting vpnctld..."

  if command -v jq >/dev/null 2>&1; then
    # `. > 0`, not `. != 0`: active.json lives under a normal user's own
    # home directory and is fully user-writable, so a hand-edited negative
    # PID here must never reach `kill` — kill(-N, sig) doesn't fail, it
    # broadcasts the signal to an entire process *group*, and kill(-1, sig)
    # (from an "engine_pid": -1, say) signals every process this script's
    # caller (root, during install) has permission to signal, i.e. the
    # whole machine.
    pids="$(jq -r '
      [.engine_pid, .helper_pid, .health_pid] + [(.processes // [])[].pid]
      | .[] | select(type == "number" and . > 0 and (. % 1 == 0))
    ' "$active_json" 2>/dev/null)"
    for pid in $pids; do
      case "$pid" in
        ''|*[!0-9]*) continue ;;
      esac
      kill "$pid" 2>/dev/null || true
    done
    if [ -n "$pids" ]; then
      sleep 0.3
      for pid in $pids; do
        case "$pid" in
          ''|*[!0-9]*) continue ;;
        esac
        kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
      done
    fi
  fi

  if command -v ip >/dev/null 2>&1 && ip netns list 2>/dev/null | grep -q '^vpnctl0\b'; then
    log "namespace vpnctl0 still present after teardown, removing it"
    ip netns del vpnctl0 2>/dev/null || true
  fi

  if [ -S /var/run/wireguard/vpnctl-wg.sock ]; then
    log "stale WireGuard UAPI socket found, removing it"
    rm -f /var/run/wireguard/vpnctl-wg.sock
  fi

  rm -f "$active_json"
}

run_migration() {
  [ -d /root/.local/state/vpnctl ] && migrate_from_file_based_model /root
  for state_dir in /home/*/.local/state/vpnctl; do
    [ -d "$state_dir" ] || continue
    migrate_from_file_based_model "${state_dir%/.local/state/vpnctl}"
  done
}

start_daemon() {
  if ! command -v systemctl >/dev/null 2>&1; then
    log "WARNING: systemctl not found — install/enable the vpnctld systemd unit manually (see packaging/vpnctld.service)"
    return 0
  fi
  systemctl daemon-reload
  if systemctl enable --now vpnctld; then
    log "vpnctld enabled and started (systemctl status vpnctld to check)"
  else
    log "WARNING: failed to enable/start vpnctld — check 'systemctl status vpnctld' and 'journalctl -u vpnctld'"
  fi
}

run_migration
setup_daemon_group
start_daemon

log "done. Run 'vpnctl doctor' to verify your setup, then 'vpnctl use <profile>' to get started (no sudo needed once vpnctld is running and you're in the '$VPNCTL_GROUP' group)."
exit 0
