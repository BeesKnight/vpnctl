#!/bin/bash
# vpnctl postrm — remove-vs-purge split, standard Debian
# convention: `apt remove` (arg "remove") keeps user profiles, `apt purge`
# (arg "purge") removes everything vpnctl ever created, including
# dependencies it installed itself (never ones that were already present —
# see postinst's installed_by_vpnctl.json).
#
# By the time this runs, prerm has already stopped vpnctld (which tears
# down the namespace/iptables and restores sysctl from its own backup via
# its own Shutdown()), or run the force_teardown fallback if the daemon
# didn't respond — so there is nothing network-related left to clean up
# here, only files.
set -u

STATE_DIR="/var/lib/vpnctl"
DAEMON_STATE_DIR="/var/lib/vpnctld"
DEPS_FILE="$STATE_DIR/installed_by_vpnctl.json"
UNIT_FILE="/lib/systemd/system/vpnctld.service"

remove_state_dirs() {
  [ -d /root/.local/state/vpnctl ] && rm -rf /root/.local/state/vpnctl
  for d in /home/*/.local/state/vpnctl; do
    [ -d "$d" ] && rm -rf "$d"
  done
}

remove_config_dirs() {
  [ -d /root/.config/vpnctl ] && rm -rf /root/.config/vpnctl
  for d in /home/*/.config/vpnctl; do
    [ -d "$d" ] && rm -rf "$d"
  done
}

remove_installed_deps() {
  [ -f "$DEPS_FILE" ] || return 0
  installed_singbox="false"
  installed_xray="false"
  installed_tun2socks="false"
  installed_awg_tools="false"
  installed_amneziawg_go="false"
  if command -v jq >/dev/null 2>&1; then
    installed_singbox="$(jq -r '.sing_box // false' "$DEPS_FILE" 2>/dev/null || echo false)"
    installed_xray="$(jq -r '.xray_core // false' "$DEPS_FILE" 2>/dev/null || echo false)"
    installed_tun2socks="$(jq -r '.tun2socks // false' "$DEPS_FILE" 2>/dev/null || echo false)"
    installed_awg_tools="$(jq -r '.amneziawg_tools // .amneziawg // false' "$DEPS_FILE" 2>/dev/null || echo false)"
    installed_amneziawg_go="$(jq -r '.amneziawg_go // .amneziawg // false' "$DEPS_FILE" 2>/dev/null || echo false)"
  else
    grep -q '"sing_box": *true' "$DEPS_FILE" && installed_singbox="true"
    grep -q '"xray_core": *true' "$DEPS_FILE" && installed_xray="true"
    grep -q '"tun2socks": *true' "$DEPS_FILE" && installed_tun2socks="true"
    grep -Eq '"amneziawg_tools": *true|"amneziawg": *true' "$DEPS_FILE" && installed_awg_tools="true"
    grep -Eq '"amneziawg_go": *true|"amneziawg": *true' "$DEPS_FILE" && installed_amneziawg_go="true"
  fi

  if [ "$installed_singbox" = "true" ]; then
    echo "vpnctl postrm: removing sing-box (installed by vpnctl)"
    rm -f /usr/bin/sing-box /usr/local/bin/sing-box
  fi
  if [ "$installed_xray" = "true" ]; then
    echo "vpnctl postrm: removing xray (installed by vpnctl)"
    rm -f /usr/bin/xray /usr/local/bin/xray
  fi
  if [ "$installed_tun2socks" = "true" ]; then
    echo "vpnctl postrm: removing tun2socks (installed by vpnctl)"
    rm -f /usr/bin/tun2socks /usr/local/bin/tun2socks
  fi
  if [ "$installed_awg_tools" = "true" ]; then
    echo "vpnctl postrm: removing amneziawg-tools (installed by vpnctl)"
    rm -f /usr/bin/awg-quick /usr/bin/awg /usr/local/bin/awg-quick /usr/local/bin/awg
  fi
  if [ "$installed_amneziawg_go" = "true" ]; then
    echo "vpnctl postrm: removing amneziawg-go (installed by vpnctl)"
    rm -f /usr/bin/amneziawg-go /usr/local/bin/amneziawg-go
  fi
}

# remove_daemon_unit is a defensive cleanup in case nfpm/dpkg didn't already
# remove the unit file it owns (e.g. a leftover from a manual install done
# before this file was tracked in nfpm.yaml's contents:). daemon-reload
# clears systemd's cached view of it either way; harmless if there was
# nothing to reload.
remove_daemon_unit() {
  rm -f "$UNIT_FILE"
  command -v systemctl >/dev/null 2>&1 && systemctl daemon-reload 2>/dev/null || true
}

case "${1:-}" in
  remove)
    # Ephemeral runtime state is always cleared; user profiles are not
    # touched — that's the whole point of `remove` vs `purge`.
    remove_state_dirs
    ;;
  purge)
    remove_state_dirs
    remove_config_dirs
    remove_installed_deps
    remove_daemon_unit
    rm -rf "$STATE_DIR"
    rm -rf "$DAEMON_STATE_DIR"
    # The 'vpnctl' group is left in place even on purge: deleting a group
    # that's still referenced as another user's supplementary group (or
    # just recently used) is more likely to surprise someone than a stray,
    # harmless group left behind — not worth the risk for a purge script.
    ;;
  *)
    # upgrade/failed-upgrade/etc: nothing to do
    ;;
esac

exit 0
